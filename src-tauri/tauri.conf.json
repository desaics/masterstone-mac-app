{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Masterstone",
  "version": "0.1.0",
  "identifier": "com.masterstone.crm",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Masterstone CRM",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "category": "Business",
    "shortDescription": "Masterstone CRM",
    "longDescription": "Native macOS desktop app for the Masterstone CRM — Phase 1 scaffold."
  }
}
