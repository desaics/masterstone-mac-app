{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Masterstone",
  "version": "0.8.7",
  "identifier": "com.masterstone.crm",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Masterstone CRM",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "category": "Business",
    "shortDescription": "Masterstone CRM",
    "longDescription": "Native macOS desktop app for Masterstone CRM — Phase 2 (Session 5): live SQLite editing, OneDrive link routing, and iPhone HTML snapshot export."
  }
}
